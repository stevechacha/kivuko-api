DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
# Railway sets DATABASE_URL automatically when you add PostgreSQL.
# Railway sets RAILWAY_PUBLIC_DOMAIN automatically for the web service.
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081
PUBLIC_VERIFY_BASE_URL=https://kivukohub.go.tz/verify
PUBLIC_APP_BASE_URL=https://kivuko-web-production.up.railway.app
ADMIN_DASHBOARD_KEY=
